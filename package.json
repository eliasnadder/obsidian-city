{
  "name": "obsidian-city-backend",
  "version": "0.1.0",
  "description": "ObsidianCity3D — Backend API for parsing Obsidian vault into 3D city data",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node server.ts",
    "dev:js": "nodemon server.js",
    "test": "node test-parser.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "joi": "^18.0.2",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "supertest": "^7.2.2",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.4",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
