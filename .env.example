VAULT_PATH=/absolute/path/to/your/obsidian-vault
OBSIDIAN_CITY_PORT=3333
CACHE_TTL=300
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
CORS_ORIGIN=*

# Optional Gemini AI integration. Leave empty to keep AI features disabled.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_THINKING_BUDGET=0
AI_FEATURES_ENABLED=true
AI_CACHE_TTL=900

# Optional JWT auth. Leave empty to keep auth disabled.
JWT_SECRET=
JWT_EXPIRES_IN=24h

# Optional demo admin password used by /api/auth/login when JWT is enabled.
JWT_ADMIN_PASSWORD=change-me
